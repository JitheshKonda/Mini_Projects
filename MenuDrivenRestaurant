import java.util.Scanner;

public class Restaurant {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.println("1. Biryani");
        System.out.println("2. Pizza");
        System.out.println("3. Burger");
        System.out.println("4. Dosa");

        System.out.print("Choose Item: ");
        int choice = sc.nextInt();

        switch(choice) {

            case 1:
                System.out.println("Biryani Price = Rs.250");
                break;

            case 2:
                System.out.println("Pizza Price = Rs.300");
                break;

            case 3:
                System.out.println("Burger Price = Rs.120");
                break;

            case 4:
                System.out.println("Dosa Price = Rs.80");
                break;

            default:
                System.out.println("Item Not Available");
        }
    }
}
